      "scene_id": "scene_01",
      "order": 1,
      "title": "The Village in Peril",
      "visual_description": "A small village surrounded by a dense forest, with smoke rising from the chimneys of the thatched roof cottages.",
      "mood": "tense",
      "setting": "village",
      "duration_sec": 60,
      "dialogues": [
        {
          "line_id": "line_01",
          "character_id": "char_01",
          "text": "What's happening, Lila? Why is everyone so scared?",
          "emotion": "concerned",
          "scene_id": "scene_01"
        },
        {
          "line_id": "line_02",
          "character_id": "char_03",
          "text": "Eira, my child, the dark sorcerer Malakai has returned, and he seeks to destroy our village.",
          "emotion": "serious",
          "scene_id": "scene_01"
        }
      ]
    },
    {
      "scene_id": "scene_02",
      "order": 2,
      "title": "The Mage's Training",
      "visual_description": "A young Eira practicing her magic in a secluded clearing, surrounded by candles and ancient tomes.",
      "mood": "reflective",
      "setting": "clearing",
      "duration_sec": 90,
      "dialogues": [
        {
          "line_id": "line_03",
          "character_id": "char_01",
          "text": "I've been practicing for months, but I still feel so uncertain.",
          "emotion": "doubtful",
          "scene_id": "scene_02"
        },
        {
          "line_id": "line_04",
          "character_id": "char_03",
          "text": "Patience, Eira. Your power will grow with time and practice.",
          "emotion": "encouraging",
          "scene_id": "scene_02"
        }
      ]
    },
    {
      "scene_id": "scene_03",
      "order": 3,
      "title": "The Dark Sorcerer's Return",
      "visual_description": "Malakai standing in the village square, surrounded by his dark minions, as Eira watches from a distance.",
      "mood": "ominous",
      "setting": "village square",
      "duration_sec": 120,
      "dialogues": [
        {
          "line_id": "line_05",
          "character_id": "char_02",
          "text": "Fools! You think you can defeat me? I will crush this village and everyone in it!",
          "emotion": "menacing",
          "scene_id": "scene_03"
        },
        {
          "line_id": "line_06",
          "character_id": "char_01",
          "text": "I won't let you, Malakai. I'll stop you, no matter what it takes.",
          "emotion": "determined",
          "scene_id": "scene_03"
        }
      ]
    }
