  "scenes": [
    {
      "scene_id": "scene_01",
      "order": 1,
      "title": "The Unexpected Encounter",
      "visual_description": "A spaceship hurtling through the vastness of space, with a faint glow of stars in the background.",
      "mood": "Suspenseful",
      "setting": "Space",
      "duration_sec": 30,
      "dialogues": [
        {
          "line_id": "line_01",
          "character_id": "char_01",
          "text": "What in the world...?",
          "emotion": "Surprised"
        },
        {
          "line_id": "line_02",
          "character_id": "char_02",
          "text": "Greetings, human. I mean no harm.",
          "emotion": "Friendly"
        }
      ]
    },
    {
      "scene_id": "scene_02",
      "order": 2,
      "title": "The Alien's Story",
      "visual_description": "A holographic display projected in front of Jack, showing images of Zorvath's home planet.",
      "mood": "Sympathetic",
      "setting": "Space",
      "duration_sec": 45,
      "dialogues": [
        {
          "line_id": "line_03",
          "character_id": "char_02",
          "text": "My people were destroyed by a similar disaster. I'm searching for a way to prevent it from happening again.",
          "emotion": "Sad"
        },
        {
          "line_id": "line_04",
          "character_id": "char_01",
          "text": "I'm sorry to hear that. But what makes you think I can help you?",
          "emotion": "Curious"
        }
      ]
    },
    {
      "scene_id": "scene_03",
      "order": 3,
      "title": "The Plan",
      "visual_description": "A 3D model of the Earth, with a red X marked on a specific location.",
      "mood": "Determined",
      "setting": "Space",
      "duration_sec": 60,
      "dialogues": [
        {
          "line_id": "line_05",
          "character_id": "char_02",
          "text": "We need to stop the asteroid from colliding with Earth. I have a plan, but it requires your help.",
          "emotion": "Confident"
        },
        {
          "line_id": "line_06",
          "character_id": "char_01",
          "text": "What's the plan? I'm in.",
          "emotion": "Determined"
        }
      ]
    },
    {
      "scene_id": "scene_04",
      "order": 4,
      "title": "The Mission",
      "visual_description": "A spaceship hurtling towards the asteroid, with Jack and Zorvath on board.",
      "mood": "Exciting",
      "setting": "Space",
      "duration_sec": 90,
      "dialogues": [
        {
          "line_id": "line_07",
          "character_id": "char_01",
          "text": "This is it. We're going to save the world.",
          "emotion": "Excited"
        },
        {
          "line_id": "line_08",
          "character_id": "char_02",
          "text": "Together, we can do this.",
          "emotion": "Determined"
        }
      ]
    },
    {
      "scene_id": "scene_05",
      "order": 5,
      "title": "The Aftermath",
      "visual_description": "A shot of the Earth, with the asteroid safely destroyed in the background.",
      "mood": "Relieved",
      "setting": "Space",
      "duration_sec": 30,
      "dialogues": [
        {
          "line_id": "line_09",
          "character_id": "char_01",
          "text": "We did it. We saved the world.",
          "emotion": "Relieved"
        },
        {
          "line_id": "line_10",
          "character_id": "char_02",
          "text": "We make a good team, human.",
          "emotion": "Friendly"
        }
      ]
